/* Academia/Classical Design - Reaction Test */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  transition: background-color 300ms ease-out;
  user-select: none;
  -webkit-user-select: none;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  will-change: background-color;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  -webkit-user-drag: none;
  position: relative;
  background: #3D332B;
}

.tap-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  pointer-events: auto;
}

.header {
  width: 80%;
  margin: 0 auto 32rpx auto;
  position: relative;
  z-index: 2;
}

.progress-bar {
  height: 8rpx;
  background: rgba(201, 169, 98, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(74, 63, 53, 0.5);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%);
  transition: width 300ms ease-out;
}

.header-info {
  display: flex;
  justify-content: flex-end;
}

.round-text {
  color: #C9A962;
  font-size: 24rpx;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
}

.container.clickable {
  cursor: pointer;
  transition: none;
  background: #4A5D3F;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
  flex: 1;
  position: relative;
  z-index: 2;
}

.instruction-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.instruction {
  font-size: min(56rpx, 9vw);
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  letter-spacing: 2rpx;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
  margin-bottom: 16rpx;
}

.hint {
  font-size: min(28rpx, 4.5vw);
  color: #9C8B7A;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  letter-spacing: 1rpx;
}

.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 500ms ease-out;
  margin-bottom: 60rpx;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-time {
  display: flex;
  align-items: baseline;
}

.time-value {
  font-size: min(120rpx, 18vw);
  font-weight: 500;
  color: #C9A962;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
  line-height: 1;
}

.time-unit {
  font-size: min(40rpx, 6vw);
  font-weight: 500;
  color: #9C8B7A;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  margin-left: 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.stats-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 500ms ease-out;
  width: 100%;
  max-width: 600rpx;
}

.stat-card {
  background: rgba(37, 30, 25, 0.6);
  border: 1rpx solid rgba(74, 63, 53, 0.8);
  border-radius: 8rpx;
  padding: 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
}

.main-stat {
  border-color: rgba(201, 169, 98, 0.5);
  margin-bottom: 24rpx;
}

/* Corner Flourishes for Main Stat */
.main-stat::before,
.main-stat::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #C9A962;
  opacity: 0.8;
}

.main-stat::before {
  top: -1rpx;
  left: -1rpx;
  border-right: none;
  border-bottom: none;
}

.main-stat::after {
  bottom: -1rpx;
  right: -1rpx;
  border-left: none;
  border-top: none;
}

.stat-label {
  font-size: min(24rpx, 3.8vw);
  color: #9C8B7A;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: min(80rpx, 12vw);
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
  line-height: 1;
}

.stat-value .unit {
  font-size: min(32rpx, 5vw);
  font-weight: 400;
  color: #9C8B7A;
  margin-left: 8rpx;
}

.stats-row {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.stats-row .stat-card {
  flex: 1;
  padding: 32rpx 24rpx;
}

.result-grade {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.grade-text {
  font-size: min(48rpx, 7.5vw);
  font-weight: 500;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
  color: #C9A962;
}

.new-best {
  background: rgba(139, 38, 53, 0.3);
  border: 1rpx solid rgba(139, 38, 53, 0.5);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  margin-bottom: 32rpx;
  animation: bounce 600ms ease-out;
}

@keyframes bounce {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.new-best-text {
  font-size: min(32rpx, 5vw);
  font-weight: 500;
  color: #C9A962;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
}

.penalty-notice {
  background: rgba(139, 38, 53, 0.2);
  border: 1rpx solid rgba(139, 38, 53, 0.4);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  margin-bottom: 32rpx;
}

.penalty-text {
  font-size: min(28rpx, 4.5vw);
  color: #E8DFD4;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  max-width: 400rpx;
  position: relative;
  z-index: 10;
}

.btn {
  padding: 24rpx 48rpx;
  border-radius: 8rpx;
  text-align: center;
  transition: all 300ms ease-out;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2), inset 0 -1rpx 0 rgba(0, 0, 0, 0.2), 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.btn-primary:active {
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.btn-secondary {
  background: transparent;
  border: 2rpx solid #C9A962;
}

.btn-secondary:active {
  background: #8B2635;
  border-color: #8B2635;
}

.btn-text {
  font-size: min(32rpx, 5vw);
  font-weight: 500;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: #1C1714;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
}

.btn-secondary .btn-text {
  color: #C9A962;
  text-shadow: none;
}

.btn-secondary:active .btn-text {
  color: #E8DFD4;
}

@media screen and (max-width: 750rpx) {
  .content {
    padding: 32rpx 24rpx;
  }

  .stat-card {
    padding: 32rpx 40rpx;
  }

  .stats-row {
    gap: 16rpx;
  }

  .stats-row .stat-card {
    padding: 24rpx 16rpx;
  }
}

.guide-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  margin-bottom: 24rpx;
  display: block;
  text-align: center;
}

.guide-text {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: rgba(37, 30, 25, 0.5);
  border: 1rpx solid rgba(74, 63, 53, 0.8);
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.guide-desc {
  font-size: 28rpx;
  color: #9C8B7A;
  font-family: 'STSong', 'SimSun', 'Songti SC', serif;
  line-height: 1.6;
  display: block;
}
