<view class="container">
  <view class="header" style="padding-right: {{headerRight}}px;">
    <view class="header-spacer" style="height: {{capsuleTop}}px;"></view>
    <view class="header-content" style="height: {{capsuleHeight}}px;">
      <view class="title-section">
        <text class="main-title">反应力测试助手</text>
        <text class="subtitle">测试你的极限反应速度</text>
      </view>
      <view class="settings-btn" bindtap="navigateToSettings">
        <text class="settings-icon">⚙️</text>
      </view>
    </view>
  </view>

  <view class="test-grid">
    <block wx:for="{{testModes}}" wx:key="id">
      <view 
        class="test-card" 
        data-id="{{item.id}}" 
        bindtap="navigateToTest"
      >
        <view class="card-content">
          <text class="card-icon">{{item.icon}}</text>
          <view class="card-info">
            <text class="card-title">{{item.title}}</text>
            <text class="card-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
        <view class="card-score" wx:if="{{bestScores[item.id]}}">
          <text class="score-label">最佳</text>
          <text class="score-value">{{bestScores[item.id]}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="footer">
    <text class="footer-text">点击卡片开始测试</text>
  </view>

  <view class="more-section">
    <text class="more-title">更多好玩的</text>
    <text class="finger-icon">👇</text>
  </view>

  <view class="mini-program-card" bindtap="navigateToMiniProgram">
    <view class="mini-program-content">
      <text class="mini-program-icon">🎡</text>
      <view class="mini-program-info">
        <text class="mini-program-title">日常转盘</text>
        <text class="mini-program-subtitle">让转盘帮你做决定</text>
      </view>
      <text class="mini-program-arrow">→</text>
    </view>
  </view>

  <view class="mini-program-card" bindtap="navigateToWoodenFish">
    <view class="mini-program-content">
      <text class="mini-program-icon">🎐</text>
      <view class="mini-program-info">
        <text class="mini-program-title">木鱼福签</text>
        <text class="mini-program-subtitle">敲木鱼，求福签</text>
      </view>
      <text class="mini-program-arrow">→</text>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
