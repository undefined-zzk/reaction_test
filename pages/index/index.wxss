/* Academia/Classical Design - Index Page */
.container {
  min-height: 100vh;
  background: #1C1714;
  padding: 0;
  position: relative;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  background: #251E19;
  border-bottom: 1rpx solid #4A3F35;
  position: relative;
}

/* Corner Flourishes for Header */
.header::before,
.header::after {
  content: '';
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #C9A962;
}

.header::before {
  top: 0;
  left: 0;
  border-right: none;
  border-bottom: none;
}

.header::after {
  bottom: 0;
  right: 0;
  border-left: none;
  border-top: none;
}

.title-section {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 48rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  font-size: 20rpx;
}

.settings-btn {
  width: 80rpx;
  height: 80rpx;
  background: transparent;
  border: 2rpx solid #C9A962;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 300ms ease-out;
}

.settings-btn:active {
  transform: scale(0.95);
  background: rgba(201, 169, 98, 0.1);
  box-shadow: 0 0 24rpx rgba(201, 169, 98, 0.3);
}

.settings-icon {
  font-size: 40rpx;
  filter: sepia(1) hue-rotate(20deg) saturate(3);
}

.test-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  padding: 48rpx 40rpx;
  margin-top: 20rpx;
}

.test-card {
  border-radius: 8rpx;
  padding: 40rpx 32rpx;
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #251E19;
  border: 1rpx solid #4A3F35;
  box-shadow: none;
  transition: all 500ms ease-out;
  position: relative;
  overflow: visible;
}

/* Corner Flourishes for Cards */
.test-card::before,
.test-card::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #C9A962;
  opacity: 0.6;
  transition: opacity 300ms ease-out;
}

.test-card::before {
  top: -1rpx;
  left: -1rpx;
  border-right: none;
  border-bottom: none;
}

.test-card::after {
  bottom: -1rpx;
  right: -1rpx;
  border-left: none;
  border-top: none;
}

.test-card:active {
  transform: scale(0.98);
  border-color: rgba(201, 169, 98, 0.5);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.test-card:active::before,
.test-card:active::after {
  opacity: 1;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.card-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  filter: sepia(0.6) contrast(0.95) brightness(0.9);
  transition: filter 700ms ease-out;
}

.test-card:active .card-icon {
  filter: sepia(0) contrast(1) brightness(1);
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.card-subtitle {
  font-size: 22rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.card-score {
  background: rgba(201, 169, 98, 0.15);
  border: 1rpx solid rgba(201, 169, 98, 0.3);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
}

.score-label {
  font-size: 20rpx;
  color: #C9A962;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.footer {
  padding: 40rpx;
  text-align: center;
  margin-top: 20rpx;
  position: relative;
}

/* Ornate Divider */
.footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #4A3F35 20%, #C9A962 50%, #4A3F35 80%, transparent 100%);
}

.footer::after {
  content: '✶';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #C9A962;
  font-size: 24rpx;
  background: #1C1714;
  padding: 0 16rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-top: 32rpx;
  display: block;
}
