/* Academia/Classical Design - Settings Page */
.container {
  min-height: 100vh;
  background: #1C1714;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.settings-section,
.stats-section,
.danger-section {
  background: #251E19;
  border: 1rpx solid #4A3F35;
  border-radius: 8rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

/* Corner Flourishes for Sections */
.settings-section::before,
.settings-section::after,
.stats-section::before,
.stats-section::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #C9A962;
  opacity: 0.6;
}

.settings-section::before,
.stats-section::before {
  top: -1rpx;
  left: -1rpx;
  border-right: none;
  border-bottom: none;
}

.settings-section::after,
.stats-section::after {
  bottom: -1rpx;
  right: -1rpx;
  border-left: none;
  border-top: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  margin-bottom: 24rpx;
  display: block;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(74, 63, 53, 0.5);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
}

.setting-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Crimson Pro', 'SimSun', serif;
  margin-bottom: 8rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.stats-card {
  background: rgba(201, 169, 98, 0.05);
  border: 1rpx solid rgba(201, 169, 98, 0.2);
  border-radius: 8rpx;
  padding: 24rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(74, 63, 53, 0.3);
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #C9A962;
  font-family: 'Cormorant Garamond', 'STSong', serif;
}

.danger-section {
  border-color: rgba(139, 38, 53, 0.5);
}

.danger-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(139, 38, 53, 0.1);
  border-radius: 8rpx;
  border: 1rpx solid rgba(139, 38, 53, 0.3);
}

.danger-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #C9A962;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
}

.danger-icon {
  font-size: 32rpx;
  filter: sepia(0.6) contrast(0.95) brightness(0.9);
}

.footer {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

/* Ornate Divider */
.footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #4A3F35 20%, #C9A962 50%, #4A3F35 80%, transparent 100%);
}

.footer::after {
  content: '✶';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #C9A962;
  font-size: 24rpx;
  background: #1C1714;
  padding: 0 16rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
  margin-bottom: 8rpx;
  margin-top: 32rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
  font-style: italic;
}
