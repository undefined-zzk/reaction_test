/* Academia/Classical Design - Result Page */
.container {
  min-height: 100vh;
  background: #1C1714;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.result-card {
  background: #251E19;
  border: 1rpx solid #4A3F35;
  border-radius: 8rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 32rpx;
  position: relative;
}

/* Corner Flourishes */
.result-card::before,
.result-card::after {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #C9A962;
  opacity: 0.8;
}

.result-card::before {
  top: -1rpx;
  left: -1rpx;
  border-right: none;
  border-bottom: none;
}

.result-card::after {
  bottom: -1rpx;
  right: -1rpx;
  border-left: none;
  border-top: none;
}

.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 40rpx 0;
  border-radius: 8rpx;
  background: rgba(201, 169, 98, 0.05);
  border: 1rpx solid rgba(201, 169, 98, 0.2);
}

.score-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.score-value {
  font-size: 140rpx;
  font-weight: 500;
  color: #C9A962;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  line-height: 1;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
}

.score-unit {
  font-size: 40rpx;
  font-weight: 500;
  color: #9C8B7A;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-left: 12rpx;
}

.grade-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
  background: rgba(201, 169, 98, 0.15);
  border: 1rpx solid rgba(201, 169, 98, 0.3);
}

.grade-text {
  font-size: 32rpx;
  font-weight: 500;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  margin-bottom: 4rpx;
}

.grade-desc {
  font-size: 22rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.new-best-badge {
  display: inline-block;
  background: linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%);
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  animation: pulse 2s ease-in-out infinite;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2), inset 0 -1rpx 0 rgba(0, 0, 0, 0.2);
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}

.badge-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1714;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  background: rgba(201, 169, 98, 0.05);
  border: 1rpx solid rgba(201, 169, 98, 0.2);
  padding: 24rpx;
  border-radius: 8rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: #C9A962;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 3rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  display: block;
  margin-bottom: 16rpx;
}

.history-section {
  margin-bottom: 32rpx;
}

.history-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(201, 169, 98, 0.05);
  border: 1rpx solid rgba(201, 169, 98, 0.2);
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.history-score {
  font-size: 28rpx;
  font-weight: 500;
  color: #E8DFD4;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.history-time {
  font-size: 24rpx;
  color: #9C8B7A;
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.best-section {
  margin-bottom: 0;
}

.best-card {
  background: linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%);
  padding: 32rpx;
  border-radius: 8rpx;
  text-align: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2), inset 0 -1rpx 0 rgba(0, 0, 0, 0.2), 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.best-score {
  display: block;
  font-size: 48rpx;
  font-weight: 500;
  color: #1C1714;
  font-family: 'Cormorant Garamond', 'STSong', serif;
  margin-bottom: 8rpx;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
}

.best-date {
  font-size: 24rpx;
  color: rgba(28, 23, 20, 0.8);
  font-family: 'Crimson Pro', 'SimSun', serif;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  padding: 28rpx 48rpx;
  border-radius: 8rpx;
  text-align: center;
  transition: all 300ms ease-out;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2), inset 0 -1rpx 0 rgba(0, 0, 0, 0.2), 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.btn-primary:active {
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.btn-secondary {
  background: transparent;
  border: 2rpx solid #C9A962;
}

.btn-secondary:active {
  background: #8B2635;
  border-color: #8B2635;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid rgba(201, 169, 98, 0.5);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 500;
  font-family: 'Cinzel', 'STSong', serif;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: #1C1714;
  text-shadow: 1rpx 1rpx 1rpx rgba(0, 0, 0, 0.4), -1rpx -1rpx 1rpx rgba(255, 255, 255, 0.1);
}

.btn-secondary .btn-text,
.btn-outline .btn-text {
  color: #C9A962;
  text-shadow: none;
}

.btn-secondary:active .btn-text {
  color: #E8DFD4;
}
