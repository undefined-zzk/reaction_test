# 抖音小程序 Git 忽略文件

# 开发工具相关
.project
.idea/
.vscode/
*.swp
*.swo
*~

# 构建产物
node_modules/
dist/
build/
*.min.js
*.min.css

# 抖音小程序 npm 构建产物
miniprogram_npm/


# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 依赖目录
jspm_packages/

# 可选 npm 缓存目录
.npm

# 可选 REPL 历史
.node_repl_history

# 抖音小程序特有文件
# 开发工具生成的临时文件
.unpackage/
.project/

# 配置文件（不包含项目配置文件）
*.local.json
*.private.json

# 操作系统生成的文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE 特定文件
*.sublime-project
*.sublime-workspace

# 临时文件
*.tmp
*.temp

# 测试相关
coverage/
.nyc_output/

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 包管理器锁定文件（可选，根据团队规范决定是否忽略）
# package-lock.json
# yarn.lock

# 构建工具缓存
.cache/
.parcel-cache/

# 抖音开发者工具缓存
.douyin/

# 自定义构建目录
.output/

# 类型声明文件（TypeScript）
*.d.ts

# 调试文件
*.pdb

.trae
.agents